@startuml TicTacToe

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBorderRadius 6
skinparam ArrowColor #73726c
skinparam ClassBorderColor #7F77DD
skinparam ClassBackgroundColor #EEEDFE
skinparam ClassHeaderBackgroundColor #AFA9EC
skinparam NoteBackgroundColor #FAEEDA
skinparam style strictuml
skinparam linetype ortho

class MyExceptions {
}

class InvalidArgumentException
class InvalidMoveException
class InvalidSymbolException
class GameAlreadyFinishedException

MyExceptions +-- InvalidArgumentException
MyExceptions +-- InvalidMoveException
MyExceptions +-- InvalidSymbolException
MyExceptions +-- GameAlreadyFinishedException

abstract class Board {
  + {abstract} size() const : size_t
  + {abstract} operator()(x : size_t, y : size_t) : char&
  + {abstract} operator()(x : size_t, y : size_t) const : char
  + {abstract} full() const : bool
  + {abstract} clear() : void
  + {abstract} ~Board()
}

class "operator<<" as OpOut << (F,orchid) free function >> {
    + operator<<(out : ostream&, b : const Board&) : ostream&
}

class "BoardExt<T>" as BoardExt {
  - _n      : size_t
  - _fields : std::vector<T>
  + BoardExt(n : size_t)
  + ~BoardExt()
  + size() const : size_t
  + operator()(x : size_t, y : size_t) : char&
  + operator()(x : size_t, y : size_t) const : char
  + full() const : bool
  + clear() : void
}

class Move {
  - _x : size_t
  - _y : size_t
  + Move(x : size_t, y : size_t)
  + x() const : size_t
  + y() const : size_t
}

abstract class Strategy {
  + {abstract} chooseMove(b : const Board&, symbol : char) : Move
  + {abstract} ~Strategy()
}

class MinMaxStrategy {
  + chooseMove(b : const Board&, symbol : char) : Move
  + ~MinMaxStrategy()
  - minmax(b : const Board&, symbol : char, isMaximizing : bool) : int
  - evaluate(b : const Board&, symbol : char) : int
}

class AlphaBetaStrategy {
  + chooseMove(b : const Board&, symbol : char) : Move
  + ~AlphaBetaStrategy()
  - alphaBeta(b : const Board&, symbol : char, isMaximizing : bool, alpha : int, beta : int) : int
  - evaluate(b : const Board&, symbol : char) : int
}

class TicTacToeGame {
  - _board       : Board*
  - _xStrategy   : Strategy*
  - _oStrategy   : Strategy*
  - _currentTurn : char
  + TicTacToeGame(b : Board*, xStrategy : Strategy*, oStrategy : Strategy*)
  + ~TicTacToeGame()
  + makeMove(m : Move, symbol : char) : bool
  + play() : void
  + finished() const : bool
  + winner() const : char
  + changeStrategy(symbol : char, newStrategy : Strategy*) : void
}

Board       <|--  BoardExt
Strategy    <|--  MinMaxStrategy
Strategy    <|--  AlphaBetaStrategy

TicTacToeGame o--> Board     : _board
TicTacToeGame o--> Strategy  : _xStrategy
TicTacToeGame o--> Strategy  : _oStrategy

Strategy     ..>  Board      : <<uses>>
Strategy     ..>  Move       : <<creates>>

TicTacToeGame ..> Move       : <<uses>>

Board         ..>  MyExceptions : <<throws>>
BoardExt      ..>  MyExceptions : <<throws>>
Move          ..>  MyExceptions : <<throws>>
Strategy      ..>  MyExceptions : <<throws>>
MinMaxStrategy     ..>  MyExceptions : <<throws>>
AlphaBetaStrategy  ..>  MyExceptions : <<throws>>
TicTacToeGame ..>  MyExceptions : <<throws>>

OpOut ..> Board : <<uses>>

@enduml